<!-- filter form for properties.ejs -->
<form method="GET" action="/properties">
    <fieldset>
        <legend>Filter by Review Rating</legend>

        <label>
            <input type="radio" name="op" value="gte" <%= filter?.op === 'gte' ? 'checked' : '' %>>
            $gte (at least)
        </label>

        <label>
            <input type="radio" name="op" value="lte" <%= filter?.op === 'lte' ? 'checked' : '' %>>
            $lte (at most)
        </label>

        <label for="rating">Rating</label>
        <select id="rating" name="rating">
            <option value="1" <%= Number(filter?.rating) === 1 ? 'selected' : '' %>>1</option>
            <option value="2" <%= Number(filter?.rating) === 2 ? 'selected' : '' %>>2</option>
            <option value="3" <%= Number(filter?.rating) === 3 ? 'selected' : '' %>>3</option>
            <option value="4" <%= Number(filter?.rating) === 4 ? 'selected' : '' %>>4</option>
            <option value="5" <%= Number(filter?.rating) === 5 ? 'selected' : '' %>>5</option>
        </select>

        <button type="submit">Apply Filter</button>
        <a href="/properties">Clear</a>
    </fieldset>
</form>